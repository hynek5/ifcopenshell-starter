class Element:
    def __init__(self, name, uhc, ifc_type, loc_x, loc_y, loc_z, dim_x, dim_y):
        self.name = name
        self.uhc = float(uhc)
        self.ifc_type = ifc_type
        self.loc_x = float(loc_x)
        self.loc_y = float(loc_y)
        self.loc_z = float(loc_z)
        self.dim_x = float(dim_x)
        self.dim_y = float(dim_y)

